# Copy to .env (gitignored) for local dev.

# Java for Spark 3.5
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# AWS profile / region for development
AWS_PROFILE=default
AWS_REGION=us-east-1

# Structured logging
ETL_LOG_LEVEL=INFO
ETL_LOG_FORMAT=console

# Local dev overrides for secrets (bypasses AWS Secrets Manager)
LOCAL_SECRETS_OVERRIDE=true
LOCAL_SAP_HOST=localhost
LOCAL_SAP_PORT=5433
LOCAL_SAP_USER=sap_reader
LOCAL_SAP_PASSWORD=localpassword
LOCAL_SAP_DATABASE=sap_source

LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5432
LOCAL_PG_USER=sap_mdm_admin
LOCAL_PG_PASSWORD=localpassword
LOCAL_PG_DATABASE=sap_mdm

# Spark
SPARK_WAREHOUSE=/tmp/spark-warehouse
